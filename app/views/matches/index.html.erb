<section class="matches-page page-section">

  <div class="matches-filters app-card">
    <button type="button" class="matches-filters__toggle" data-filters-toggle>
      <%= t("filters.title") %>
      <span>▾</span>
    </button>

    <div class="matches-filters__content" data-filters-content>
      <%= form_with url: matches_path, method: :get, local: true, class: "matches-filters__form" do %>

        <div class="matches-filters__group">
          <label><%= t("matches.stage") %></label>
          <%= select_tag :stage,
                options_for_select(
                  [
                    [t("filters.all_feminine"), ""],
                    [t("stages.group_stage"), "group_stage"],
                    [t("stages.second_phase"), "second_phase"],
                    [t("stages.round_of_16"), "round_of_16"],
                    [t("stages.quarterfinal"), "quarterfinal"],
                    [t("stages.semifinal"), "semifinal"],
                    [t("stages.third_place"), "third_place"],
                    [t("stages.final"), "final"]
                  ],
                  params[:stage]
                ),
                class: "matches-filters__select" %>
        </div>

        <div class="matches-filters__group">
          <label><%= t("matches.group") %></label>
          <%= select_tag :group,
                options_for_select(
                  [[t("filters.all_masculine"), ""]] + @available_groups.map { |g| [t("matches.group_with_code", code: g), g] },
                  params[:group]
                ),
                class: "matches-filters__select" %>
        </div>

        <div class="matches-filters__group">
          <label><%= t("matches.status") %></label>
          <%= select_tag :status,
                options_for_select(
                  [
                    [t("filters.all_masculine"), ""],
                    [t("matches.statuses.open_plural"), "open"],
                    [t("matches.statuses.closed_plural"), "closed"]
                  ],
                  params[:status]
                ),
                class: "matches-filters__select" %>
        </div>

        <div class="matches-filters__group">
          <label><%= t("predictions.title") %></label>
          <%= select_tag :prediction_status,
                options_for_select(
                  [
                    [t("matches.all_matches"), ""],
                    [t("predictions.with_prediction"), "with_prediction"],
                    [t("predictions.without_prediction"), "without_prediction"]
                  ],
                  params[:prediction_status]
                ),
                class: "matches-filters__select" %>
        </div>

        <div class="matches-filters__actions">
          <%= submit_tag t("filters.apply"), class: "btn btn-primary" %>
          <%= link_to t("filters.clear"), matches_path, class: "btn-secondary-custom" %>
        </div>

      <% end %>
    </div>
  </div>

  <% if @matches.any? %>
    <div class="matches-grid">

      <% @matches.each do |match| %>
        <% prediction = @predictions_by_match_id[match.id] || current_user.predictions.build(match: match) %>
        <% locked = match.locked? || match.finished? %>

        <article id="match-<%= match.id %>" class="match-card <%= 'match-card--locked' if locked %>">

          <div class="match-card__top">
            <div class="match-card__meta">

              <span class="match-card__badge">
                <%= t("stages.#{match.stage}", default: match.phase_label) %>
                <% if match.group_code.present? %>
                  • <%= t("matches.group_with_code", code: match.group_code) %>
                <% end %>
              </span>

              <span class="match-card__status <%= locked ? 'match-card__status--closed' : 'match-card__status--open' %>">
                <%= locked ? t("matches.closed") : t("matches.open") %>
              </span>

            </div>

            <div class="match-card__datetime">
              <span><%= l(match.kickoff_at, format: :short) %>
                    <span class="timezone-label">
                      (<%= timezone_label %>)
                    </span>
              </span>
            </div>
          </div>

          <%= form_with model: prediction,
                        url: prediction.persisted? ? prediction_path(prediction) : predictions_path,
                        method: prediction.persisted? ? :patch : :post,
                        local: true,
                        data: { turbo: false },
                        class: "match-card__form" do |f| %>

            <%= f.hidden_field :match_id, value: match.id %>

            <%= hidden_field_tag :stage, params[:stage] %>
            <%= hidden_field_tag :group, params[:group] %>
            <%= hidden_field_tag :status, params[:status] %>
            <%= hidden_field_tag :prediction_status, params[:prediction_status] %>
            <%= hidden_field_tag :return_to, request.fullpath %>

            <div class="match-card__prediction-row">

              <span class="match-card__team-name match-card__team-name--home">
                <%= translated_team_name(match.home_team_name) %>
              </span>

              <div class="match-card__flag">
                <%= image_tag(match.home_team_flag_url, alt: match.home_team_name) rescue image_tag("flags/default.png", alt: t("teams.default_flag")) %>
              </div>

              <%= f.number_field :predicted_home_score,
                    value: prediction.predicted_home_score,
                    min: 0,
                    class: "match-card__input match-card__input--inline",
                    disabled: locked %>

              <div class="match-card__vs"><%= t("matches.versus") %></div>

              <%= f.number_field :predicted_away_score,
                    value: prediction.predicted_away_score,
                    min: 0,
                    class: "match-card__input match-card__input--inline",
                    disabled: locked %>

              <div class="match-card__flag">
                <%= image_tag(match.away_team_flag_url, alt: match.away_team_name) rescue image_tag("flags/default.png", alt: t("teams.default_flag")) %>
              </div>

              <span class="match-card__team-name match-card__team-name--away">
                <%= translated_team_name(match.away_team_name) %>
              </span>

            </div>

            <div class="match-card__content">

              <div class="match-card__scores">

                <div class="match-card__score-block">
                  <label><%= t("matches.official_score") %></label>
                  <div class="match-card__official-score">
                    <% if match.home_score.present? && match.away_score.present? %>
                      <strong><%= match.home_score %> x <%= match.away_score %></strong>
                    <% else %>
                      <span class="match-card__empty"><%= t("matches.not_finished") %></span>
                    <% end %>
                  </div>
                </div>

                <div class="match-card__score-block">
                  <label><%= t("matches.points") %></label>
                  <div class="match-card__points">
                    <% if prediction.persisted? && match.finished? %>
                      <strong><%= prediction.points || 0 %> <%= t("dashboard.points_abbr") %></strong>
                    <% else %>
                      <span class="match-card__empty">—</span>
                    <% end %>
                  </div>
                </div>

              </div>

              <div class="match-card__footer">
                <% unless locked %>
                  <div class="match-card__actions">
                    <%= f.submit prediction.persisted? ? t("predictions.update") : t("predictions.save"),
                          class: "btn btn-primary" %>
                  </div>
                <% else %>
                  <span class="match-card__locked-message">
                    <%= t("predictions.closed_for_match") %>
                  </span>
                <% end %>
              </div>

            </div>

          <% end %>

          <% if prediction.persisted? && !locked %>
            <div class="match-card__actions">
              <%= button_to t("predictions.clear"),
                    prediction_path(prediction),
                    method: :delete,
                    params: {
                      return_to: request.fullpath
                    },
                    form: {
                      data: { turbo: false },
                      class: "match-card__delete-form",
                      onsubmit: "return confirm('#{t("predictions.confirm_clear")}');"
                    },
                    class: "btn btn-secondary" %>
            </div>
          <% end %>

        </article>
      <% end %>

    </div>

  <% else %>

    <div class="matches-empty app-card">
      <h2><%= t("matches.empty_title") %></h2>
      <p><%= t("matches.empty_description") %></p>
    </div>

  <% end %>

</section>
