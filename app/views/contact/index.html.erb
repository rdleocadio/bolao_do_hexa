<section class="contact-page">
  <div class="contact-hero">
    <div class="container contact-hero__content">
      <h1><%= t("contact.title") %></h1>

      <p><%= t("contact.subtitle") %></p>
    </div>
  </div>

  <div class="container contact-content">
    <div class="contact-grid">
      <aside class="contact-card contact-card--pix">
        <div class="contact-card__header">
          <span class="contact-icon contact-icon--pix">
            <i class="fa-solid fa-heart"></i>
          </span>

          <div>
            <h2><%= t("contact.support.title") %></h2>
          </div>
        </div>

        <p><%= t("contact.support.description_1") %></p>

        <p><%= t("contact.support.description_2") %></p>

        <div class="pix-box">
          <span><%= t("contact.pix.key_label") %></span>
          <strong>63.485.641/0001-01</strong>
        </div>

        <div class="pix-box pix-box--small">
          <span><%= t("contact.pix.name_label") %></span>
          <strong>RL Tecnologia da Informacao</strong>
        </div>

        <div class="donation-highlight">
          <i class="fa-solid fa-hand-holding-heart"></i>
          <p><%= t("contact.support.donation") %></p>
        </div>

        <p class="contact-note"><%= t("contact.support.accountability") %></p>

        <strong class="contact-thanks"><%= t("contact.support.thanks") %></strong>
      </aside>

      <div class="contact-card contact-card--form">
        <div class="contact-card__header">
          <span class="contact-icon">
            <i class="fa-solid fa-envelope"></i>
          </span>

          <div>
            <h2><%= t("contact.form.title") %></h2>
            <p><%= t("contact.form.description") %></p>
          </div>
        </div>

        <form class="contact-form" action="https://formspree.io/f/mvzldonq" method="post">
          <div class="contact-form__group">
            <label for="contact_name"><%= t("contact.form.name") %></label>
            <input
              type="text"
              id="contact_name"
              name="name"
              placeholder="<%= t("contact.form.placeholders.name") %>"
            >
          </div>

          <div class="contact-form__group">
            <label for="contact_email"><%= t("contact.form.email") %></label>
            <input
              type="email"
              id="contact_email"
              name="email"
              placeholder="<%= t("contact.form.placeholders.email") %>"
            >
          </div>

          <div class="contact-form__group">
            <label for="contact_subject"><%= t("contact.form.subject") %></label>
            <select id="contact_subject" name="subject">
              <option value=""><%= t("contact.form.options.select") %></option>
              <option value="suporte"><%= t("contact.form.options.support") %></option>
              <option value="parceria"><%= t("contact.form.options.partnership") %></option>
              <option value="sugestao"><%= t("contact.form.options.suggestion") %></option>
              <option value="outro"><%= t("contact.form.options.other") %></option>
            </select>
          </div>

          <div class="contact-form__group">
            <label for="contact_message"><%= t("contact.form.message") %></label>
            <textarea
              id="contact_message"
              name="message"
              rows="6"
              placeholder="<%= t("contact.form.placeholders.message") %>"
            ></textarea>
          </div>

          <button type="submit" class="contact-button">
            <i class="fa-solid fa-paper-plane"></i>
            <%= t("contact.form.submit") %>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
