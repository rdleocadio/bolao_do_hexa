<section class="dashboard-page user-profile-page page-section">
  <div class="app-card user-profile-card">
    <div class="user-profile-card__header">
      <div class="user-profile-card__main">
        <div class="dashboard-avatar">
          <% if @user.avatar.attached? %>
            <%= image_tag @user.avatar, alt: @user.name.presence || @user.email %>
          <% else %>
            <div class="dashboard-avatar__placeholder">
              <%= (@user.name.presence || @user.email).first.upcase %>
            </div>
          <% end %>
        </div>

        <div>
          <p class="dashboard-hero__eyebrow"><%= t("user_profile.eyebrow") %></p>
          <h1 class="dashboard-hero__title">
            <%= @user.name.presence || @user.email %>
          </h1>
        </div>
      </div>

      <div class="user-profile-stats">
        <div class="user-profile-stat">
          <span><%= t("dashboard.total_score") %></span>
          <strong><%= @total_points %> <%= t("dashboard.points_abbr") %></strong>
        </div>
      </div>
    </div>
  </div>

  <div class="app-card dashboard-leagues-card">
    <div class="dashboard-leagues-card__header">
      <div>
        <p class="dashboard-section__eyebrow"><%= t("user_profile.leagues_eyebrow") %></p>
        <h2 class="dashboard-section__title"><%= t("user_profile.leagues_title") %></h2>
      </div>
    </div>

    <% if @leagues.any? %>
      <div class="table-responsive">
        <table class="dashboard-leagues-table">
          <thead>
            <tr>
              <th><%= t("user_profile.table.league") %></th>
              <th><%= t("user_profile.table.position") %></th>
            </tr>
          </thead>

          <tbody>
            <% @leagues.each do |league| %>
              <% league_image =
                if league.respond_to?(:photo) && league.photo.attached?
                  league.photo
                elsif league.respond_to?(:avatar) && league.avatar.attached?
                  league.avatar
                elsif league.respond_to?(:image) && league.image.attached?
                  league.image
                elsif league.respond_to?(:logo) && league.logo.attached?
                  league.logo
                elsif league.respond_to?(:cover) && league.cover.attached?
                  league.cover
                end
              %>

              <tr>
                <td>
                  <%= link_to league_path(league), class: "dashboard-league-row" do %>
                    <span class="dashboard-league-avatar">
                      <% if league_image.present? %>
                        <%= image_tag league_image, alt: league.name %>
                      <% else %>
                        <span class="dashboard-league-avatar__placeholder">
                          <%= league.name.first.upcase %>
                        </span>
                      <% end %>
                    </span>

                    <span class="dashboard-league-link"><%= league.name %></span>
                  <% end %>
                </td>

                <td>
                  <span class="dashboard-position-badge">
                    <% if @league_positions[league.id].present? %>
                      <%= t("rankings.ordinal", position: @league_positions[league.id]) %>
                    <% else %>
                      -
                    <% end %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dashboard-empty-state">
        <p><%= t("user_profile.empty_leagues") %></p>
      </div>
    <% end %>
  </div>

  <div class="app-card dashboard-leagues-card">
    <div class="dashboard-leagues-card__header">
      <div>
        <p class="dashboard-section__eyebrow"><%= t("predictions.title") %></p>
        <h2 class="dashboard-section__title"><%= t("user_profile.predictions_title") %></h2>
      </div>
    </div>

    <% if @predictions.any? %>
      <div class="table-responsive">
        <table class="dashboard-leagues-table">
          <thead>
            <tr>
              <th><%= t("matches.match") %></th>
              <th><%= t("predictions.short_label") %></th>
              <th><%= t("matches.result") %></th>
              <th><%= t("matches.points") %></th>
            </tr>
          </thead>

          <tbody>
            <% @predictions.each do |prediction| %>
              <% match = prediction.match %>
              <% home_team = match.home_team_name %>
              <% away_team = match.away_team_name %>

              <tr>
                <td>
                  <div class="prediction-match-row">
                    <%= image_tag(match.home_team_flag_url, class: "prediction-flag", alt: home_team) rescue image_tag("flags/default.png", class: "prediction-flag", alt: home_team) %>

                    <strong><%= t("matches.versus") %></strong>

                    <%= image_tag(match.away_team_flag_url, class: "prediction-flag", alt: away_team) rescue image_tag("flags/default.png", class: "prediction-flag", alt: away_team) %>
                  </div>
                </td>

                <td>
                  <%= prediction.predicted_home_score %> x <%= prediction.predicted_away_score %>
                </td>

                <td>
                  <% if match.finished? %>
                    <%= match.home_score %> x <%= match.away_score %>
                  <% else %>
                    -
                  <% end %>
                </td>

                <td>
                  <span class="dashboard-position-badge">
                    <%= prediction.points %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="dashboard-empty-state">
        <p><%= t("user_profile.empty_predictions") %></p>
      </div>
    <% end %>
  </div>
</section>
