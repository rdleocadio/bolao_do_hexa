<section class="landing-hero">
  <div class="landing-hero__overlay"></div>

  <div class="landing-hero__content container">
    <div class="landing-hero__text">
      <p class="landing-hero__eyebrow"><%= t("home.eyebrow") %></p>

      <h1 class="landing-hero__title">
        <%= t("home.title") %>
      </h1>

      <p class="landing-hero__description">
        <%= t("home.description") %>
      </p>

      <div class="landing-hero__highlights">
        <span><%= t("home.highlights.league_ranking") %></span>
        <span><%= t("home.highlights.match_predictions") %></span>
        <span><%= t("home.highlights.guaranteed_fun") %></span>
      </div>
    </div>

    <div class="landing-login-card" id="login">
      <div class="landing-login-card__header">
        <div class="landing-login-card__header-row">
          <div class="landing-login-card__logo">
            <%= image_tag "logo-podcast.png",
                alt: "Canarinho Cast",
                class: "landing-login-card__logo-img" %>
          </div>

          <div class="landing-login-card__title-group">
            <p class="landing-login-card__eyebrow"><%= t("home.login.eyebrow") %></p>
            <h2><%= t("home.login.title") %></h2>
          </div>
        </div>
      </div>

      <% if alert.present? %>
        <div class="alert alert-danger">
          <%= alert %>
        </div>
      <% end %>

      <% if notice.present? %>
        <div class="alert alert-success">
          <%= notice %>
        </div>
      <% end %>

      <%= form_with scope: :user,
            url: user_session_path,
            local: true,
            data: { turbo: false },
            class: "landing-login-form" do |f| %>

        <div class="landing-form-group">
          <%= f.label :email, t("forms.email") %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "landing-form-input",
                placeholder: t("forms.placeholders.email"),
                value: params.dig(:user, :email) %>
        </div>

        <div class="landing-form-group">
          <%= f.label :password, t("forms.password") %>
          <%= f.password_field :password,
                autocomplete: "current-password",
                class: "landing-form-input",
                placeholder: t("forms.placeholders.password") %>
        </div>

        <div class="landing-form-row">
          <label class="landing-checkbox">
            <%= f.check_box :remember_me %>
            <span><%= t("forms.remember_me") %></span>
          </label>

          <%= link_to t("forms.forgot_password"), new_user_password_path, class: "landing-forgot-link" %>
        </div>

        <%= f.submit t("navbar.login"), class: "landing-submit-button" %>
      <% end %>

      <div class="landing-login-card__footer">
        <p><%= t("home.login.no_account") %></p>
        <%= link_to t("navbar.register"), new_user_registration_path, class: "landing-secondary-link" %>
      </div>
    </div>
  </div>
</section>
