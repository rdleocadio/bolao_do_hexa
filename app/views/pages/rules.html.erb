<section class="rules-page page-section">
  <div class="app-card rules-card">
    <p class="dashboard-section__eyebrow"><%= t("rules.eyebrow") %></p>

    <h1 class="section-title">
      <%= t("rules.title") %>
    </h1>

    <div class="rules-content">

      <h2><%= t("rules.scoring.title") %></h2>

      <ul>
        <li>
          <strong><%= t("rules.scoring.exact.title") %></strong>
          <%= t("rules.scoring.exact.description") %>
        </li>

        <li>
          <strong><%= t("rules.scoring.partial.title") %></strong>
          <%= t("rules.scoring.partial.description") %>
        </li>

        <li>
          <strong><%= t("rules.scoring.winner.title") %></strong>
          <%= t("rules.scoring.winner.description") %>
        </li>

        <li>
          <strong><%= t("rules.scoring.error.title") %></strong>
          <%= t("rules.scoring.error.description") %>
        </li>
      </ul>

      <h2><%= t("rules.tie_breaker.title") %></h2>

      <ol>
        <li><%= t("rules.tie_breaker.rule_1") %></li>
        <li><%= t("rules.tie_breaker.rule_2") %></li>
        <li><%= t("rules.tie_breaker.rule_3") %></li>
        <li><%= t("rules.tie_breaker.rule_4") %></li>
        <li><%= t("rules.tie_breaker.rule_5") %></li>
      </ol>

      <h2><%= t("rules.lock.title") %></h2>

      <p>
        <%= t("rules.lock.description") %>
      </p>
    </div>
  </div>
</section>
