<div class="brackets-page">

  <div class="brackets-mobile-filter">
    <label for="brackets-stage-filter"><%= t("brackets.filter_stage") %></label>

    <select id="brackets-stage-filter">
      <option value="all"><%= t("brackets.all_stages") %></option>
      <option value="second-phase"><%= t("brackets.second_phase") %></option>
      <option value="round-of-16"><%= t("brackets.round_of_16") %></option>
      <option value="quarterfinal"><%= t("brackets.quarterfinal") %></option>
      <option value="semifinal"><%= t("brackets.semifinal") %></option>
      <option value="third-place"><%= t("brackets.third_place") %></option>
      <option value="final"><%= t("brackets.final") %></option>
    </select>
  </div>

  <section class="brackets-board-wrapper">
    <div class="brackets-board">

      <div class="brackets-column-wrapper" data-stage="second-phase">
        <%= render "stage_column",
              title: t("brackets.second_phase"),
              matches: @second_phase_matches,
              predictions_by_match_id: @predictions_by_match_id %>
      </div>

      <div class="brackets-column-wrapper" data-stage="round-of-16">
        <%= render "stage_column",
              title: t("brackets.round_of_16"),
              matches: @round_of_16_matches,
              predictions_by_match_id: @predictions_by_match_id %>
      </div>

      <div class="brackets-column-wrapper" data-stage="quarterfinal">
        <%= render "stage_column",
              title: t("brackets.quarterfinal"),
              matches: @quarterfinal_matches,
              predictions_by_match_id: @predictions_by_match_id %>
      </div>

      <div class="brackets-column-wrapper" data-stage="semifinal">
        <%= render "stage_column",
              title: t("brackets.semifinal"),
              matches: @semifinal_matches,
              predictions_by_match_id: @predictions_by_match_id %>
      </div>

      <div class="brackets-column-wrapper" data-stage="third-place">
        <div class="brackets-column brackets-column--finals">
          <h2><%= t("brackets.third_place") %></h2>

          <% if @third_place_match.present? %>
            <%= render "match_card",
                  match: @third_place_match,
                  predictions_by_match_id: @predictions_by_match_id %>
          <% else %>
            <div class="bracket-empty-card">
              <%= t("brackets.third_place_not_registered") %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="brackets-column-wrapper" data-stage="final">
        <div class="brackets-column brackets-column--finals">
          <h2><%= t("brackets.final") %></h2>

          <% if @final_match.present? %>
            <%= render "match_card",
                  match: @final_match,
                  predictions_by_match_id: @predictions_by_match_id %>
          <% else %>
            <div class="bracket-empty-card">
              <%= t("brackets.final_not_registered") %>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </section>
</div>
