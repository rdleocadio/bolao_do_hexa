<section class="leagues-dashboard-page page-section">
  <div class="leagues-dashboard__hero">
    <div class="leagues-dashboard__hero-main">
      <div class="leagues-dashboard__hero-user">
        <div class="leagues-dashboard__hero-profile">
          <%= link_to user_path(@user), class: "leagues-dashboard__avatar" do %>
            <% if @user.avatar.attached? %>
              <%= image_tag @user.avatar, alt: @user.name.presence || @user.email %>
            <% else %>
              <div class="leagues-dashboard__avatar-placeholder">
                <%= (@user.name.presence || @user.email).first.upcase %>
              </div>
            <% end %>
          <% end %>

          <div class="leagues-dashboard__profile-action">
            <%= link_to t("navbar.edit_profile"), edit_user_registration_path, class: "btn-sm-subtle" %>
          </div>
        </div>

        <div class="leagues-dashboard__hero-copy">
          <p class="leagues-dashboard__eyebrow"><%= t("dashboard.title") %></p>
          <h1 class="section-title">
            <%= t("dashboard.welcome_user", user: @user.name.presence || @user.email) %>
          </h1>
        </div>
      </div>

      <div class="leagues-dashboard__summary">
        <div class="leagues-dashboard__summary-card">
          <p class="leagues-dashboard__summary-label"><%= t("dashboard.total_score") %></p>

          <div class="leagues-dashboard__summary-metric">
            <span class="leagues-dashboard__summary-number"><%= @total_points %></span>
            <span class="leagues-dashboard__summary-suffix"><%= t("dashboard.points_abbr") %></span>
          </div>

          <p class="leagues-dashboard__summary-meta">
            <%= t("dashboard.finished_matches") %>
          </p>
        </div>
      </div>
    </div>
  </div>

  <% if @upcoming_matches_without_predictions.present? && @upcoming_matches_without_predictions.any? %>
    <div class="leagues-dashboard__upcoming-card">
      <div class="leagues-dashboard__upcoming-header">
        <h2><%= t("dashboard.upcoming_without_predictions.title") %></h2>
        <p><%= t("dashboard.upcoming_without_predictions.description") %></p>
      </div>

      <div class="leagues-dashboard__upcoming-list">
        <% @upcoming_matches_without_predictions.each do |match| %>
          <div class="leagues-dashboard__upcoming-item">
            <div class="leagues-dashboard__upcoming-date">
              <%= l(match.kickoff_at, format: :short) %>
              <span class="timezone-label">
                (<%= timezone_label %>)
              </span>
            </div>

            <div class="leagues-dashboard__upcoming-teams">
              <span><%= translated_team_name(match.home_team_name) %></span>

              <%= image_tag(match.home_team_flag_url,
                  class: "leagues-dashboard__upcoming-flag",
                  alt: match.home_team_name) rescue image_tag("flags/default.png",
                  class: "leagues-dashboard__upcoming-flag",
                  alt: t("teams.default_flag")) %>

              <strong><%= t("matches.versus") %></strong>

              <%= image_tag(match.away_team_flag_url,
                  class: "leagues-dashboard__upcoming-flag",
                  alt: match.away_team_name) rescue image_tag("flags/default.png",
                  class: "leagues-dashboard__upcoming-flag",
                  alt: t("teams.default_flag")) %>

              <span><%= translated_team_name(match.away_team_name) %></span>
            </div>

            <%= link_to t("predictions.predict"),
                matches_path(anchor: "match-#{match.id}"),
                class: "btn-primary-custom leagues-dashboard__upcoming-button" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="leagues-dashboard__section-card">
    <div class="leagues-dashboard__section-header">
      <div>
        <p class="leagues-dashboard__eyebrow"><%= t("leagues.your_leagues") %></p>
      </div>

      <div class="leagues-dashboard__header-actions">
        <%= link_to t("leagues.other_leagues"), discover_leagues_path, class: "btn-secondary-custom" %>
        <%= link_to t("leagues.create"), new_league_path, class: "btn-primary-custom" %>
      </div>
    </div>

    <% if @leagues.any? %>
      <div class="leagues-dashboard__table-wrap">
        <table class="leagues-dashboard__table">
          <thead>
            <tr>
              <th><%= t("leagues.table.leagues_you_joined") %></th>
              <th><%= t("leagues.table.your_position") %></th>
              <th><%= t("leagues.table.entry_code") %></th>
              <th><%= t("leagues.table.creator") %></th>
              <th><%= t("leagues.table.type") %></th>
            </tr>
          </thead>

          <tbody>
            <% @leagues.each do |league| %>
              <tr>
                <td>
                  <%= link_to league_path(league), class: "leagues-dashboard__league-link" do %>
                    <div class="leagues-dashboard__league-avatar">
                      <% if league.image.attached? %>
                        <%= image_tag league.image, alt: league.name %>
                      <% else %>
                        <div class="leagues-dashboard__league-avatar-placeholder">
                          <%= league.name.first.upcase %>
                        </div>
                      <% end %>
                    </div>

                    <span><%= league.name %></span>
                  <% end %>
                </td>

                <td>
                  <span class="leagues-dashboard__position-badge">
                    <%= t("rankings.ordinal", position: @league_positions[league.id]) %>
                  </span>
                </td>

                <td>
                  <span class="dashboard-position-badge">
                    <%= league.code %>
                  </span>
                </td>

                <td>
                  <%= league.owner.name.presence || league.owner.email %>
                </td>

                <td>
                  <% if league.private? %>
                    <span class="discover-status discover-status--pending"><%= t("leagues.status.private") %></span>
                  <% else %>
                    <span class="discover-status discover-status--approved"><%= t("leagues.status.open") %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="leagues-dashboard__empty">
        <p><%= t("leagues.empty") %></p>
      </div>
    <% end %>
  </div>
</section>
