<section class="page-section">
  <div class="app-card league-form-card">
    <div class="league-form-card__header">
      <p class="dashboard-section__eyebrow"><%= t("league_new.eyebrow") %></p>
      <h1 class="dashboard-section__title"><%= t("leagues.create") %></h1>

      <p class="league-form-card__text">
        <%= t("league_new.description") %>
      </p>
    </div>

    <%= form_with model: @league, local: true, class: "league-form" do |f| %>
      <% if @league.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @league.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="league-form__group">
        <%= f.label :name, t("league_new.name") %>
        <%= f.text_field :name,
              class: "landing-form-input",
              placeholder: t("league_new.placeholders.name") %>
      </div>

      <div class="league-form__group">
        <%= f.label :image, t("league_new.image") %>
        <%= f.file_field :image, class: "landing-form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :private, t("league_new.type") %>

        <%= f.select :private,
              [
                [t("leagues.status.open"), false],
                [t("leagues.status.private"), true]
              ],
              {},
              class: "form-control" %>
      </div>

      <div class="league-form__actions">
        <%= link_to t("buttons.back"),
              leagues_path,
              class: "btn-secondary-custom" %>

        <%= f.submit t("leagues.create"),
              class: "btn-primary-custom" %>
      </div>
    <% end %>
  </div>
</section>
