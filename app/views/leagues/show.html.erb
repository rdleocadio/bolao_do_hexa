<% stage_labels = {
  "group_stage" => t("stages.group_stage"),
  "second_phase" => t("stages.second_phase"),
  "round_of_16" => t("stages.round_of_16"),
  "quarterfinal" => t("stages.quarterfinal"),
  "semifinal" => t("stages.semifinal"),
  "third_place" => t("stages.third_place"),
  "final" => t("stages.final")
} %>

<% sorted_ranking = @ranking.sort_by do |entry|
  [
    -entry[:points].to_i,
    -entry[:exact_scores].to_i,
    -entry[:partial_scores].to_i,
    -entry[:winners].to_i,
    entry[:errors].to_i
  ]
end %>

<section class="page-section">
  <div class="app-card league-show-hero">
    <div class="league-show-hero__main">
      <div class="league-show-avatar">
        <% if @league.image.attached? %>
          <%= image_tag @league.image, alt: @league.name %>
        <% else %>
          <div class="league-show-avatar__placeholder">
            <%= @league.name.first.upcase %>
          </div>
        <% end %>
      </div>

      <div>
        <p class="dashboard-section__eyebrow"><%= t("league.profile") %></p>

        <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
          <h1 class="dashboard-hero__title"><%= @league.name %></h1>

          <% if @is_owner %>
            <%= link_to t("leagues.edit"),
                edit_league_path(@league),
                class: "btn-secondary-custom" %>
          <% end %>
        </div>

        <% if @user_position.present? %>
          <p class="league-show-position">
            <%= t("league.your_position") %>
            <strong><%= t("rankings.ordinal", position: @user_position) %></strong>
          </p>
        <% end %>

        <p class="league-show-meta">
          <%= t("league.code") %>
          <strong><%= @league.code %></strong>
        </p>

        <p class="league-show-meta">
          <%= t("league.created_by") %>
          <strong><%= @league.owner.name.presence || @league.owner.email %></strong>
        </p>

        <p class="league-show-meta">
          <%= t("league.invite_link") %>
          <%= league_url(@league) %>
        </p>
      </div>
    </div>

    <% if @current_membership.present? %>
      <% if @current_membership.pending? %>
        <div class="alert league-show-alert" style="background: #fff6dd; color: #7a5a00; border-color: #f1dda0;">
          <%= t("league.membership.pending") %>
        </div>
      <% elsif @current_membership.rejected? %>
        <div class="alert league-show-alert">
          <%= t("league.membership.rejected") %>
        </div>
      <% end %>
    <% end %>

    <div class="league-show-actions">
      <% unless @current_membership.present? %>
        <%= button_to t("league.request_entry"),
            join_league_path(@league),
            method: :post,
            class: "btn-primary-custom" %>
      <% end %>

      <%= link_to t("leagues.title"),
          leagues_path,
          class: "btn-secondary-custom" %>

      <%= link_to t("leagues.discover"),
          discover_leagues_path,
          class: "btn-secondary-custom" %>
    </div>
  </div>

  <div class="app-card dashboard-leagues-card">
    <h3 class="dashboard-section__title"><%= t("ranking.title") %></h3>

    <% if sorted_ranking.any? %>
      <div class="table-responsive">
        <table class="dashboard-leagues-table ranking-table">
          <thead>
            <tr>
              <th><%= t("ranking.position") %></th>
              <th><%= t("ranking.participant") %></th>
              <th><%= t("ranking.points") %></th>
              <th><%= t("ranking.exact_score") %></th>
              <th><%= t("ranking.partial_score") %></th>
              <th><%= t("ranking.winner_draw") %></th>
              <th><%= t("ranking.errors") %></th>
            </tr>
          </thead>

          <tbody>
            <% sorted_ranking.each_with_index do |entry, index| %>
              <tr>
                <td>
                  <% if index == 0 %>
                    🥇
                  <% elsif index == 1 %>
                    🥈
                  <% elsif index == 2 %>
                    🥉
                  <% else %>
                    <%= index + 1 %>
                  <% end %>
                </td>

                <td>
                  <%= link_to user_path(entry[:user]), class: "dashboard-league-link user-inline" do %>
                    <div class="user-inline__avatar">
                      <% if entry[:user].avatar.attached? %>
                        <%= image_tag entry[:user].avatar %>
                      <% else %>
                        <div class="user-inline__placeholder">
                          <%= (entry[:user].name.presence || entry[:user].email).first.upcase %>
                        </div>
                      <% end %>
                    </div>

                    <span class="user-inline__name">
                      <%= entry[:user].name.presence || entry[:user].email %>
                    </span>
                  <% end %>
                </td>

                <td><strong><%= entry[:points].to_i %></strong></td>
                <td><%= entry[:exact_scores].to_i %></td>
                <td><%= entry[:partial_scores].to_i %></td>
                <td><%= entry[:winners].to_i %></td>
                <td><%= entry[:errors].to_i %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <p class="league-show-meta" style="margin-top: 12px;">
        <%= t("ranking.tie_breaker") %>
      </p>
    <% else %>
      <p><%= t("ranking.empty") %></p>
    <% end %>
  </div>

  <% if @is_owner %>
    <div class="app-card dashboard-leagues-card">
      <h3 class="dashboard-section__title"><%= t("league.pending_requests") %></h3>

      <% if @pending_memberships.any? %>
        <ul class="list-group list-group-flush">
          <% @pending_memberships.each do |membership| %>
            <li class="league-member-row">
              <div class="league-member-row__info">
                <div class="user-inline__avatar">
                  <% if membership.user.avatar.attached? %>
                    <%= image_tag membership.user.avatar %>
                  <% else %>
                    <div class="user-inline__placeholder">
                      <%= (membership.user.name.presence || membership.user.email).first.upcase %>
                    </div>
                  <% end %>
                </div>

                <div>
                  <strong><%= membership.user.name.presence || membership.user.email %></strong>
                  <div class="text-muted small"><%= membership.user.email %></div>
                </div>
              </div>

              <div class="league-member-row__actions">
                <%= button_to t("buttons.approve"),
                    approve_league_membership_path(membership),
                    method: :patch,
                    class: "btn-primary-custom" %>

                <%= button_to t("buttons.reject"),
                    reject_league_membership_path(membership),
                    method: :patch,
                    class: "btn-secondary-custom" %>
              </div>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p><%= t("league.no_pending_requests") %></p>
      <% end %>
    </div>
  <% end %>

  <div class="app-card dashboard-leagues-card">
    <h3 class="dashboard-section__title"><%= t("matches.next_matches") %></h3>

    <% if @upcoming_matches.any? %>
      <div class="table-responsive">
        <table class="dashboard-leagues-table matches-table">
          <thead>
            <tr>
              <th><%= t("matches.match") %></th>
              <th><%= t("matches.stage") %></th>
              <th><%= t("matches.date") %></th>
              <th><%= t("matches.status") %></th>
            </tr>
          </thead>

          <tbody>
            <% @upcoming_matches.each do |match| %>
              <tr>
                <td>
                  <strong class="league-show-match-teams">

                    <%= image_tag(match.home_team_flag_url,
                        class: "league-show-match-flag",
                        alt: match.home_team_name) rescue image_tag("flags/default.png",
                        class: "league-show-match-flag",
                        alt: t("teams.default_flag")) %>

                    <span><%= t("matches.versus") %></span>

                    <%= image_tag(match.away_team_flag_url,
                        class: "league-show-match-flag",
                        alt: match.away_team_name) rescue image_tag("flags/default.png",
                        class: "league-show-match-flag",
                        alt: t("teams.default_flag")) %>

                  </strong>
                </td>

                <td><%= stage_labels[match.stage.to_s] || match.stage.to_s.humanize %></td>
                <td><%= l(match.kickoff_at, format: :short) %>
                  <span class="timezone-label">
                    (<%= timezone_label %>)
                  </span>
                </td>

                <td>
                  <% if match.finished? %>
                    <span class="dashboard-position-badge">
                      <%= match.home_score %> x <%= match.away_score %>
                    </span>
                  <% elsif match.locked? %>
                    <span class="discover-status discover-status--pending">
                      <%= t("matches.locked") %>
                    </span>
                  <% else %>
                    <span class="discover-status discover-status--approved">
                      <%= t("matches.open") %>
                    </span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p><%= t("matches.no_pending") %></p>
    <% end %>
  </div>
</section>
