<section class="landing-hero">
  <div class="landing-hero__overlay"></div>

  <div class="landing-hero__content container">
    <div class="landing-hero__text">
      <p class="landing-hero__eyebrow">Bolão oficial da sua galera</p>

      <h1 class="landing-hero__title">
        Viva o melhor da Copa do Mundo com seus amigos.
      </h1>

      <p class="landing-hero__description">
        Preencha seus palpites, crie ou entre em ligas, acompanhe a classificação dos grupos e siga o mata-mata.
      </p>

      <div class="landing-hero__highlights">
        <span>🏆 Ranking por liga</span>
        <span>⚽ Palpites por jogo</span>
        <span>🧩 Diversão garantida</span>
      </div>
    </div>

    <div class="landing-login-card">
      <div class="landing-login-card__header">
        <div class="landing-login-card__header-row">
          <%= image_tag "logo-podcast.png", alt: "Bolão do Hexa", class: "landing-login-card__logo-img" %>

          <div class="landing-login-card__title-group">
            <p class="landing-login-card__eyebrow">Recuperar acesso</p>
            <h2>Redefinir senha</h2>
          </div>
        </div>
      </div>

      <%= form_for(resource,
            as: resource_name,
            url: password_path(resource_name),
            html: { method: :post, class: "landing-login-form" }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="landing-form-group">
          <%= f.label :email, "E-mail" %>
          <%= f.email_field :email,
                autofocus: true,
                autocomplete: "email",
                class: "landing-form-input",
                placeholder: "voce@email.com" %>
        </div>

        <%= f.submit "Enviar instruções", class: "landing-submit-button" %>
      <% end %>

      <div class="landing-login-card__footer">
        <p>Lembrou sua senha?</p>
        <%= link_to "Voltar para login", new_user_session_path, class: "landing-secondary-link" %>
      </div>
    </div>
  </div>
</section>
