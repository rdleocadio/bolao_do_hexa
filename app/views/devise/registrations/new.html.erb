<section class="signup-page">
  <div class="signup-hero">
    <div class="signup-hero__overlay"></div>

    <div class="signup-hero__content container">
      <div class="landing-hero__text">
        <p class="landing-hero__eyebrow"><%= t("home.eyebrow") %></p>

        <h1 class="landing-hero__title">
          <%= t("home.title") %>
        </h1>

        <p class="landing-hero__description">
          <%= t("home.description") %>
        </p>

        <div class="landing-hero__highlights">
          <span><%= t("home.highlights.league_ranking") %></span>
          <span><%= t("home.highlights.match_predictions") %></span>
          <span><%= t("home.highlights.guaranteed_fun") %></span>
        </div>
      </div>

      <div class="signup-card">
        <div class="signup-card__header">
          <div class="signup-card__header-row">
            <%= image_tag "logo-podcast.png",
                alt: t("app.title"),
                class: "signup-card__logo-img" %>

            <div class="signup-card__title-group">
              <p class="signup-card__eyebrow"><%= t("signup.eyebrow") %></p>
              <h2><%= t("signup.title") %></h2>
            </div>
          </div>
        </div>

        <%= form_for(resource,
              as: resource_name,
              url: registration_path(resource_name),
              html: { class: "signup-form" }) do |f| %>

          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="signup-form__group">
            <%= f.label :name, t("forms.name") %>
            <%= f.text_field :name,
                  autofocus: true,
                  class: "signup-form__input",
                  placeholder: t("forms.placeholders.full_name") %>
          </div>

          <div class="signup-form__group">
            <%= f.label :email, t("forms.email") %>
            <%= f.email_field :email,
                  autocomplete: "email",
                  class: "signup-form__input",
                  placeholder: t("forms.placeholders.email") %>
          </div>

          <div class="signup-form__group">
            <%= f.label :password, t("forms.password") %>

            <% if @minimum_password_length %>
              <p class="signup-form__hint">
                <%= t("profile_edit.minimum_password_length", count: @minimum_password_length) %>
              </p>
            <% end %>

            <%= f.password_field :password,
                  autocomplete: "new-password",
                  class: "signup-form__input",
                  placeholder: t("signup.placeholders.password") %>
          </div>

          <div class="signup-form__group">
            <%= f.label :password_confirmation, t("signup.password_confirmation") %>
            <%= f.password_field :password_confirmation,
                  autocomplete: "new-password",
                  class: "signup-form__input",
                  placeholder: t("signup.placeholders.password_confirmation") %>
          </div>

          <div class="signup-form__group signup-form__terms">
            <label class="signup-form__terms-label">
              <%= f.check_box :accept_terms,
                    required: true,
                    class: "signup-form__checkbox" %>

              <span>
                <%= t("signup.terms.prefix") %>
                <%= link_to t("signup.terms.terms_link"),
                    terms_path,
                    target: "_blank",
                    rel: "noopener" %>
                <%= t("signup.terms.middle") %>
                <%= link_to t("signup.terms.privacy_link"),
                    privacy_path,
                    target: "_blank",
                    rel: "noopener" %>.
              </span>
            </label>
          </div>

          <%= f.submit t("navbar.register"), class: "signup-submit-button" %>
        <% end %>

        <div class="signup-card__footer">
          <p><%= t("signup.already_have_account") %></p>
          <%= link_to t("signup.sign_in_now"),
              new_user_session_path,
              class: "signup-secondary-link" %>
        </div>
      </div>
    </div>
  </div>
</section>
